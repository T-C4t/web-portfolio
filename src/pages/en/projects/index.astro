---
import Layout from '../../../layouts/Layout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { projects, categories } from '../../../data/projects';

const lang = 'en';
---

<Layout title="Projects - Richard Matečka">
  <section class="projects-page">
    <header class="projects-header">
      <p class="page-label">Selected Work</p>
      <h1 class="page-title">Projects</h1>
      <div class="page-divider"></div>
      <p class="page-description">
        A collection of projects showcasing my work in web development,
        interactive visualizations, and creative coding.
      </p>
    </header>

    <div class="filter-section">
      <button class="filter-btn active" data-filter="all">
        All
      </button>
      {categories.map((category) => (
        <button class="filter-btn" data-filter={category.id}>
          {category.label.en}
        </button>
      ))}
    </div>

    <div class="projects-grid" id="projects-grid">
      {projects.map((project) => (
        <ProjectCard project={project} lang={lang} />
      ))}
    </div>

    <p class="no-results" id="no-results" style="display: none;">
      No projects found in this category.
    </p>
  </section>
</Layout>

<script>
  function initFilter() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const projectCards = document.querySelectorAll('.project-card');
    const noResults = document.getElementById('no-results');

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');
        let visibleCount = 0;

        projectCards.forEach((project) => {
          const category = project.getAttribute('data-category');
          
          if (filter === 'all' || category === filter) {
            (project as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (project as HTMLElement).style.display = 'none';
          }
        });

        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      });
    });
  }

  initFilter();
  document.addEventListener('astro:page-load', initFilter);
</script>

<style>
  .projects-page {
    padding: 4rem 2rem;
    background-color: var(--bg-color);
  }

  .projects-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    opacity: 0.5;
    margin: 0 0 1rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    letter-spacing: -0.02em;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .page-divider {
    width: 80px;
    height: 6px;
    background: #ffe047;
    margin: 0 auto 1.5rem auto;
  }

  .page-description {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .filter-section {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .filter-btn {
    padding: 0.625rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 700;
    background: transparent;
    border: 4px solid #3d0066;
    border-radius: 0;
    color: #3d0066;
    cursor: pointer;
    font-family: var(--font-mono);
    transition: none;
    box-shadow: 4px 4px 0 #3d0066;
  }

  .filter-btn:hover {
    background: #3d0066;
    color: #ffe047;
    box-shadow: 2px 2px 0 #3d0066;
  }

  .filter-btn.active {
    background: #3d0066;
    border-color: #3d0066;
    color: #ffe047;
    box-shadow: none;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .no-results {
    text-align: center;
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.5;
    padding: 4rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
