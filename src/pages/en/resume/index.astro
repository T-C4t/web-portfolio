---
import Layout from '../../../layouts/Layout.astro';

const lang = 'en';
---

<Layout title="Resume - Richard Matečka">
  <div class="resume-container">
    <header class="resume-header">
      <p class="resume-label">Resume</p>
      <h1 class="resume-name">Richard Matečka</h1>
      <div class="resume-divider"></div>
      <p class="resume-tagline">
        Student at Gymnázium PORG. Building AI-powered applications, autonomous agents, and creative software solutions.
      </p>
    </header>

    <section class="resume-section">
      <h2 class="section-title">Experience</h2>
      <div class="experience-list">
        <div class="experience-item">
          <div class="experience-header">
            <h3 class="job-title">Game Jam Participant — <a href="https://www.spseiostrava.cz/cs/" target="_blank" rel="noopener">Kratochvilka</a></h3>
            <span class="company">Game Development</span>
            <span class="period">2024, 2025</span>
          </div>
          <p class="experience-description">
            Participated in two editions of the Kratochvílka game jam at SPŠE Ostrava, building games under tight time constraints. Also developed an app for MSVK (IBO/Digiflow) as part of the programming seminar.
          </p>
        </div>
      </div>
    </section>

    <section class="resume-section">
      <h2 class="section-title">Education</h2>
      <div class="education-list">
        <div class="education-item">
          <div class="education-header">
            <h3 class="degree"><a href="https://www.porg.cz/porg-ostrava/" target="_blank" rel="noopener">Gymnázium PORG Ostrava</a></h3>
            <span class="school">Ostrava</span>
            <span class="period">Current</span>
          </div>
          <p class="education-description">
            Secondary education with focus on programming and computer science. Planning to study IT in Prague — considering Unicorn University or MUKK.
          </p>
        </div>
      </div>
    </section>

    <section class="resume-section">
      <h2 class="section-title">Skills</h2>
      
      <div class="skills-grid">
        <div class="skill-category">
          <h3 class="category-title">Technical</h3>
          <p class="skill-text"><span class="skill-tag">Machine Learning</span><span class="skill-tag">AI</span><span class="skill-tag">Agentic Software Dev</span><span class="skill-tag">Software Dev</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Languages & Tools</h3>
          <p class="skill-text"><span class="skill-tag">JavaScript/TypeScript</span><span class="skill-tag">Python</span><span class="skill-tag">React/Next.js</span><span class="skill-tag">Linux/Bash</span><span class="skill-tag">Render</span><span class="skill-tag">WordPress</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Soft Skills</h3>
          <p class="skill-text"><span class="skill-tag">Problem-solving</span><span class="skill-tag">Adaptable</span><span class="skill-tag">Self-starter</span><span class="skill-tag">Quick learner</span><span class="skill-tag">Detail-oriented</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Languages</h3>
          <p class="skill-text"><span class="skill-tag">Czech — Native</span><span class="skill-tag">English — C1</span><span class="skill-tag">French — B1</span></p>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .resume-container {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    background-color: var(--bg-color);
  }

  .resume-header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 5px solid #3d0066;
  }

  .resume-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    opacity: 0.5;
    margin: 0 0 1rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-name {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-divider {
    width: 80px;
    height: 6px;
    background: #ffe047;
    margin: 0 auto 1.5rem auto;
  }

  .resume-tagline {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 500px;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-section {
    margin-bottom: 3rem;
    padding: 1.5rem;
    border: 3px solid #3d0066;
    box-shadow: 4px 4px 0 #3d0066;
    background: #ede0f8;
  }

  .section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin: 0 0 2rem 0;
    color: var(--text-color);
    opacity: 0.6;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .experience-item,
  .education-item {
    margin-bottom: 2.5rem;
  }

  .experience-header,
  .education-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .job-title,
  .degree {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-color);
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .company,
  .school {
    font-weight: 400;
    color: var(--text-color);
    opacity: 0.7;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .period {
    font-size: 0.875rem;
    color: var(--text-color);
    opacity: 0.5;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .experience-description,
  .education-description {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text-color);
    opacity: 0.75;
    line-height: 1.7;
    max-width: 650px;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }

  .skill-category {
    padding: 0;
  }

  .category-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: var(--text-color);
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .skill-text {
    font-size: 0.875rem;
    color: var(--text-color);
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.6875rem;
    padding: 0.25rem 0.625rem;
    background: #3d0066;
    border-radius: 0;
    color: #ffe047;
    opacity: 1;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .resume-header {
      text-align: center;
    }

    .resume-divider {
      margin: 0 auto 1.5rem auto;
    }

    .experience-header,
    .education-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
