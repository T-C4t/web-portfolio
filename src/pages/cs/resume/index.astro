---
import Layout from '../../../layouts/Layout.astro';

const lang = 'cs';
---

<Layout title="Životopis - Richard Matečka">
  <div class="resume-container">
    <header class="resume-header">
      <p class="resume-label">Životopis</p>
      <h1 class="resume-name">Richard Matečka</h1>
      <div class="resume-divider"></div>
      <p class="resume-tagline">
        Full-stack vývojář s vášní pro tvorbu elegantních řešení
        a objevování nových technologií.
      </p>
    </header>

    <section class="resume-section">
      <h2 class="section-title">Dovednosti</h2>
      
      <div class="skills-grid">
        <div class="skill-category">
          <h3 class="category-title">Technické</h3>
          <p class="skill-text"><span class="skill-tag">Webový vývoj</span><span class="skill-tag">Moderní frameworky</span><span class="skill-tag">Best practices</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Nástroje</h3>
          <p class="skill-text"><span class="skill-tag">Interaktivní zážitky</span><span class="skill-tag">Pozornost k detailu</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Měkké dovednosti</h3>
          <p class="skill-text"><span class="skill-tag">Řešení problémů</span><span class="skill-tag">Kreativní myšlení</span></p>
        </div>

        <div class="skill-category">
          <h3 class="category-title">Jazyky</h3>
          <p class="skill-text"><span class="skill-tag">Angličtina (rodný)</span><span class="skill-tag">Čeština (rodný)</span><span class="skill-tag">Němčina (základy)</span></p>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .resume-container {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    background-color: var(--bg-color);
  }

  .resume-header {
    text-align: center;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 5px solid #3d0066;
  }

  .resume-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    opacity: 0.5;
    margin: 0 0 1rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-name {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-divider {
    width: 80px;
    height: 6px;
    background: #ffe047;
    margin: 0 auto 1.5rem auto;
  }

  .resume-tagline {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    max-width: 500px;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .resume-section {
    margin-bottom: 3rem;
    padding: 1.5rem;
    border: 3px solid #3d0066;
    box-shadow: 4px 4px 0 #3d0066;
    background: #ede0f8;
  }

  .section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin: 0 0 2rem 0;
    color: var(--text-color);
    opacity: 0.6;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .experience-item,
  .education-item {
    margin-bottom: 2.5rem;
  }

  .experience-header,
  .education-header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .job-title,
  .degree {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-color);
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .company,
  .school {
    font-weight: 400;
    color: var(--text-color);
    opacity: 0.7;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .period {
    font-size: 0.875rem;
    color: var(--text-color);
    opacity: 0.5;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .experience-description,
  .education-description {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text-color);
    opacity: 0.75;
    line-height: 1.7;
    max-width: 650px;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }

  .skill-category {
    padding: 0;
  }

  .category-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: var(--text-color);
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .skill-text {
    font-size: 0.875rem;
    color: var(--text-color);
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.6875rem;
    padding: 0.25rem 0.625rem;
    background: #3d0066;
    border-radius: 0;
    color: #ffe047;
    opacity: 1;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .resume-header {
      text-align: center;
    }

    .resume-divider {
      margin: 0 auto 1.5rem auto;
    }

    .experience-header,
    .education-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
