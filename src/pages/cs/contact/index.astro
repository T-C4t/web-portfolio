---
import Layout from '../../../layouts/Layout.astro';
import { useTranslatedPath } from '../../../i18n/utils';

const lang = 'cs';
const translatePath = useTranslatedPath(lang);

const githubUrl = 'https://github.com/T-C4t';
const emailUrl = 'mailto:richardmatecka20869@gmail.com';
---

<Layout title="Kontakt - Richard Matečka">
  <section class="contact-page">
    <header class="contact-header">
      <p class="page-label">Kontakt</p>
      <h1 class="page-title">Kontakt</h1>
      <div class="page-divider"></div>
      <p class="page-description">
        Neváhejte se ozvat ohledně spolupráce, projektů nebo jen tak na popovídání.
      </p>
    </header>

    <div class="contact-container">
      <!-- Social Links -->
      <div class="social-section">
        <h2 class="section-title">Odkazy</h2>
        
        <div class="social-links">
          <a href={githubUrl} class="social-link" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            <span>GitHub</span>
          </a>
          
          <a href={emailUrl} class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>Email</span>
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="form-section">
        <h2 class="section-title">Zpráva</h2>
        <form class="contact-form" id="contact-form">
          <input type="hidden" name="access_key" value="5340b576-1fd5-42f1-b34f-38bf7a39521c">
          <input type="hidden" name="subject" value="Nová zpráva z portfolia">
          <input type="hidden" name="from_name" value="Kontaktní formulář portfolia">
          
          <div class="form-group">
            <label for="name">Jméno</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              placeholder="Vaše jméno"
            />
          </div>
          
          <div class="form-group">
            <label for="email">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder="vas@email.com"
            />
          </div>
          
          <div class="form-group">
            <label for="message">Zpráva</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required 
              placeholder="Vaše zpráva..."
            ></textarea>
          </div>
          
          <button type="submit" class="submit-btn">
            Odeslat
          </button>
          
          <div id="form-status" class="form-status"></div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Odesílání...';
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (result.success) {
        status.textContent = 'Zpráva byla úspěšně odeslána!';
        status.className = 'form-status success';
        form.reset();
      } else {
        status.textContent = result.message || 'Něco se pokazilo. Zkuste to prosím znovu.';
        status.className = 'form-status error';
      }
    } catch {
      status.textContent = 'Chyba sítě. Zkuste to prosím znovu.';
      status.className = 'form-status error';
    }

    submitBtn.textContent = originalText;
    submitBtn.disabled = false;
  });
</script>

<style>
  .contact-page {
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    max-width: 900px;
    margin: 0 auto;
    background-color: var(--bg-color);
  }

  .contact-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-color);
    opacity: 0.5;
    margin: 0 0 1rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    letter-spacing: -0.02em;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .page-divider {
    width: 80px;
    height: 6px;
    background: #ffe047;
    margin: 0 auto 1.5rem auto;
  }

  .page-description {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    max-width: 500px;
    margin: 0 auto;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
  }

  .section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin: 0 0 1.5rem 0;
    color: var(--text-color);
    opacity: 0.6;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: #3d0066;
    border: 3px solid #3d0066;
    border-radius: 0;
    font-family: var(--font-mono);
    transition: none;
    box-shadow: 3px 3px 0 #3d0066;
    background: #ede0f8;
  }

  .social-link:hover {
    background: #3d0066;
    color: #ffe566;
    box-shadow: 1px 1px 0 #3d0066;
  }

  .social-link span {
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 3px solid #3d0066;
    box-shadow: 5px 5px 0 #3d0066;
    background: #ede0f8;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-color);
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .form-group input,
  .form-group textarea {
    padding: 1rem;
    font-size: 1rem;
    font-family: var(--font-mono);
    border: 3px solid var(--border-color);
    border-radius: 0;
    background: #f5d9ff;
    color: var(--text-color);
    width: 100%;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--purple-light);
    box-shadow: 4px 4px 0 var(--purple-light);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .submit-btn {
    padding: 1rem 2rem;
    font-size: 0.875rem;
    font-weight: 700;
    background: #3d0066;
    color: #ffe047;
    border: 4px solid #3d0066;
    border-radius: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    box-shadow: 6px 6px 0 #ffe047;
    transition: none;
    align-self: flex-start;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .submit-btn:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #ffe047;
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-status {
    padding: 0.75rem 1rem;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    font-size: 0.875rem;
    font-weight: 700;
    display: none;
  }

  .form-status.success {
    display: block;
    background: #d4edda;
    color: #155724;
    border: 2px solid #155724;
  }

  .form-status.error {
    display: block;
    background: #f8d7da;
    color: #721c24;
    border: 2px solid #721c24;
  }

  @media (max-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
