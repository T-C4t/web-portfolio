---
import Layout from '../../layouts/Layout.astro';
import { useTranslatedPath } from '../../i18n/utils';
import { projects } from '../../data/projects';

const lang = 'cs';
const translatePath = useTranslatedPath(lang);
const featuredProjects = projects.slice(0, 4);
---

<Layout title="Richard Matečka">
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-label">Portfolio</p>
        <h1 class="hero-name">
          <span class="name-first">Richard</span>
          <span class="name-last">Matečka</span>
        </h1>
        <div class="hero-divider"></div>
        <p class="hero-tagline">
          Kreativní vývojář zaměřený na tvorbu interaktivních zážitků
          a prozkoumávání průniku designu a technologie.
        </p>
        <div class="hero-cta">
          <a href={translatePath('/projects')} class="btn btn-primary">
            Zobrazit projekty
          </a>
          <a href={translatePath('/contact')} class="btn btn-secondary">
            Kontakt
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">O mně</h2>
      </div>
      <div class="about-content">
        <p class="about-text">
          Jsem vývojář z Prahy, který se pasionátně věnuje tvorbě
          smysluplných digitálních zážitků. Moje práce zahrnuje webový vývoj,
          interaktivní vizualizace a kreativní programování.
        </p>
        <p class="about-text">
          Když zrovna neprogramuji, pracuji na osobních projektech,
          experimentuji s novými technologiemi nebo přispívám do open source.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="projects-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Vybrané práce</h2>
      </div>
      
      <div class="projects-grid">
        {featuredProjects.map((project, index) => (
          <a 
            href={project.repoUrl || project.liveUrl || '#'} 
            class="project-item"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-index">{String(index + 1).padStart(2, '0')}</div>
            <div class="project-info">
              <h3 class="project-title">{project.title[lang]}</h3>
              <p class="project-category">{project.category}</p>
            </div>
            <div class="project-tags">
              {project.tags.slice(0, 3).map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
            <svg class="project-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </a>
        ))}
      </div>

      <div class="projects-cta">
        <a href={translatePath('/projects')} class="link-arrow">
          Zobrazit všechny projekty
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">Spojme se</h2>
      </div>
      <div class="contact-content">
        <p class="contact-text">
          Máte projekt na mysli nebo se chcete jen porozprávět? Vždy jsem otevřený
          novým příležitostem a nápadům.
        </p>
        <a href={translatePath('/contact')} class="btn btn-primary">
          Kontaktovat
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-name">Richard Matečka</span>
      <span class="footer-year">© 2026</span>
    </div>
  </footer>
</Layout>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 5vw;
    background-color: var(--bg-color);
  }

  .hero-content {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero-text {
    max-width: 700px;
  }

  .hero-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: var(--text-color);
    opacity: 0.5;
    margin: 0 0 2rem 0;
    font-weight: 500;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .hero-name {
    margin: 0 0 2.5rem 0;
    line-height: 0.85;
    font-weight: 600;
  }

  .name-first {
    display: block;
    font-size: clamp(4.5rem, 14vw, 10rem);
    color: var(--text-color);
    letter-spacing: -0.03em;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .name-last {
    display: block;
    font-size: clamp(4.5rem, 14vw, 10rem);
    color: var(--text-color);
    letter-spacing: -0.03em;
    margin-left: 15%;
    opacity: 0.6;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .hero-divider {
    width: 80px;
    height: 6px;
    background: #ffe047;
    margin: 0 0 2.5rem 0;
  }

  .hero-tagline {
    font-size: 1.125rem;
    color: var(--text-color);
    opacity: 0.6;
    margin: 0 0 3rem 0;
    line-height: 1.8;
    max-width: 480px;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 1rem 2rem;
    border-radius: 0;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    transition: none;
  }

  .btn-primary {
    background: #3d0066;
    color: #ffe047;
    border: 4px solid #3d0066;
    box-shadow: 6px 6px 0 #ffe047;
  }

  .btn-primary:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #ffe047;
  }

  .btn-secondary {
    background: transparent;
    color: #3d0066;
    border: 4px solid #3d0066;
    box-shadow: 6px 6px 0 #c670ff;
  }

  .btn-secondary:hover {
    background: #3d0066;
    color: #ffe047;
    box-shadow: 3px 3px 0 #c670ff;
  }

  /* Section Styles */
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8rem 5vw;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .section-number {
    font-size: 0.875rem;
    font-weight: 700;
    color: #c670ff;
    font-family: var(--font-mono);
    background: #3d0066;
    padding: 0.25rem 0.625rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 600;
    margin: 0;
    color: var(--text-color);
    letter-spacing: -0.02em;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  /* About Section */
  .about-section {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: var(--bg-color);
  }

  .about-content {
    max-width: 600px;
    padding-left: 4rem;
    border-left: 6px solid #3d0066;
  }

  .about-text {
    font-size: 1.125rem;
    color: var(--text-color);
    opacity: 0.65;
    margin: 0 0 1.5rem 0;
    line-height: 1.85;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .about-text:last-child {
    margin-bottom: 0;
  }

  /* Projects Section */
  .projects-section {
    min-height: 100vh;
    background-color: var(--bg-color);
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #3d0066;
    border: 4px solid #3d0066;
  }

  .project-item {
    display: grid;
    grid-template-columns: 60px 1fr auto auto;
    align-items: center;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: #eec7fc;
    text-decoration: none;
    border-bottom: 2px solid #3d0066;
  }

  .project-item:last-child {
    border-bottom: none;
  }

  .project-item:hover {
    background: #ffe047;
  }

  .project-item:hover .project-title {
    color: #3d0066;
  }

  .project-item:hover .project-arrow {
    transform: translate(4px, -4px);
    opacity: 1;
  }

  .project-index {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-color);
    opacity: 0.3;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .project-info {
    min-width: 0;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0 0 0.25rem 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .project-category {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-color);
    opacity: 0.4;
    margin: 0;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-tag {
    font-size: 0.6875rem;
    padding: 0.25rem 0.625rem;
    background: #3d0066;
    border-radius: 0;
    color: #ffe047;
    opacity: 1;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
  }

  .project-arrow {
    opacity: 0.3;
    color: var(--text-color);
  }

  .projects-cta {
    margin-top: 3rem;
    text-align: center;
  }

  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 700;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  .link-arrow:hover {
    color: #c670ff;
  }

  .link-arrow svg {
    transition: transform 0.3s ease;
  }

  .link-arrow:hover svg {
    transform: translateX(4px);
  }

  /* Contact Section */
  .contact-section {
    min-height: 60vh;
    display: flex;
    align-items: center;
    background-color: var(--bg-color);
  }

  .contact-content {
    max-width: 500px;
  }

  .contact-text {
    font-size: 1.125rem;
    color: var(--text-color);
    opacity: 0.6;
    margin: 0 0 2.5rem 0;
    line-height: 1.85;
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
  }

  /* Footer */
  .site-footer {
    padding: 3rem 5vw;
    border-top: 5px solid #3d0066;
    background: #3d0066;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name {
    font-size: 0.875rem;
    color: #ffe047;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .footer-year {
    font-size: 0.75rem;
    color: #c670ff;
    font-family: var(--font-mono);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .project-item {
      grid-template-columns: 40px 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }

    .project-tags,
    .project-arrow {
      display: none;
    }

    .about-content {
      padding-left: 2rem;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 6rem 1.5rem;
    }

    .name-last {
      margin-left: 8%;
    }

    .section-inner {
      padding: 5rem 1.5rem;
    }

    .about-content {
      padding-left: 1.5rem;
    }

    .footer-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
