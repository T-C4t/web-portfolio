---
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
const translatePath = useTranslatedPath(lang);

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="main-nav">
  <div class="nav-container">
    <a href={translatePath('/')} class="logo">RM</a>
    
    <div class="nav-links">
      {navLinks.map(link => (
        <a href={translatePath(link.href)} class="nav-link">{link.label}</a>
      ))}
    </div>

    <div class="nav-controls">
      <LanguagePicker />
    </div>
  </div>
</nav>

<style>
  .main-nav {
    padding: 1rem 0;
    border-bottom: 3px solid #3d0066;
    background-color: #4a0080;
    color: #f5e8ff;
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  .logo {
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    color: #ffe566;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    border: 3px solid #ffe566;
    padding: 0.2rem 0.6rem;
    box-shadow: 3px 3px 0 #ffe566;
    flex-shrink: 0;
    transition: none;
  }

  .logo:hover {
    background: #ffe566;
    color: #3d0066;
    box-shadow: none;
    transform: translate(3px, 3px);
  }

  .nav-links {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    text-decoration: none;
    color: #e8d0ff;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    padding: 0.5rem 1rem;
    border-right: 1px solid rgba(232, 208, 255, 0.2);
    transition: none;
    white-space: nowrap;
  }

  .nav-link:first-child {
    border-left: 1px solid rgba(232, 208, 255, 0.2);
  }

  .nav-link:hover {
    background: #ffe566;
    color: #3d0066;
    border-color: #ffe566;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .nav-container {
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 0.5rem 1rem;
    }

    .nav-links {
      order: 3;
      width: 100%;
      justify-content: center;
    }

    .nav-link {
      font-size: 0.7rem;
      padding: 0.4rem 0.75rem;
    }
  }
</style>
