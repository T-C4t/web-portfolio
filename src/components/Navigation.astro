---
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
const translatePath = useTranslatedPath(lang);

const navLinks = [
  { href: '/', label: t['nav.home'] },
  { href: '/projects', label: t['nav.projects'] },
  { href: '/resume', label: t['nav.resume'] },
  { href: '/contact', label: t['nav.contact'] },
];
---

<nav class="main-nav">
  <div class="nav-container">
    <a href={translatePath('/')} class="logo">RM</a>
    
    <button class="mobile-toggle" aria-label="Toggle Navigation" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <div class="nav-menu">
      <div class="nav-links">
        {navLinks.map(link => (
          <a href={translatePath(link.href)} class="nav-link">{link.label}</a>
        ))}
      </div>

      <div class="nav-controls">
        <LanguagePicker />
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const menu = document.querySelector('.nav-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isExpanded));
      menu.classList.toggle('is-open');
    });
  }
</script>

<style>
  .main-nav {
    padding: 1rem 0;
    border-bottom: 3px solid var(--border-color);
    background-color: var(--bg-alt);
    color: var(--text-on-dark);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  .logo {
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    border: 3px solid var(--accent);
    padding: 0.2rem 0.6rem;
    box-shadow: 3px 3px 0 var(--accent);
    flex-shrink: 0;
    transition: none;
    z-index: 101;
  }

  .logo:hover {
    background: var(--accent);
    color: var(--text-color);
    box-shadow: none;
    transform: translate(3px, 3px);
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
  }

  .hamburger {
    display: block;
    width: 24px;
    height: 3px;
    background: var(--accent);
    position: relative;
    transition: background 0.2s ease-out;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--accent);
    left: 0;
    transition: transform 0.2s ease-out;
  }

  .hamburger::before {
    top: -8px;
  }

  .hamburger::after {
    top: 8px;
  }

  .mobile-toggle[aria-expanded="true"] .hamburger {
    background: transparent;
  }

  .mobile-toggle[aria-expanded="true"] .hamburger::before {
    transform: translateY(8px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded="true"] .hamburger::after {
    transform: translateY(-8px) rotate(-45deg);
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: flex-end;
  }

  .nav-links {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-link {
    text-decoration: none;
    color: var(--text-on-dark);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    padding: 0.5rem 1rem;
    border-right: 1px solid rgba(232, 208, 255, 0.2);
    transition: none;
    white-space: nowrap;
  }

  .nav-link:first-child {
    border-left: 1px solid rgba(232, 208, 255, 0.2);
  }

  .nav-link:hover {
    background: var(--accent);
    color: var(--text-color);
    border-color: var(--accent);
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .mobile-toggle {
      display: block;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: var(--bg-alt);
      border-bottom: 3px solid var(--border-color);
      flex-direction: column;
      padding: 1rem 0;
      gap: 1rem;
    }

    .nav-menu.is-open {
      display: flex;
    }

    .nav-links {
      flex-direction: column;
      width: 100%;
      align-items: center;
    }

    .nav-link {
      width: 100%;
      text-align: center;
      border: none;
      border-bottom: 1px solid rgba(232, 208, 255, 0.2);
      padding: 1rem;
      font-size: 1rem;
    }

    .nav-link:first-child {
      border-left: none;
      border-top: 1px solid rgba(232, 208, 255, 0.2);
    }
  }
</style>
