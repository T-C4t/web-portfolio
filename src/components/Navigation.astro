---
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
const translatePath = useTranslatedPath(lang);

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="main-nav">
  <div class="nav-container">
    <a href={translatePath('/')} class="logo">RM</a>
    
    <div class="nav-links">
      {navLinks.map(link => (
        <a href={translatePath(link.href)} class="nav-link">{link.label}</a>
      ))}
    </div>

    <div class="nav-controls">
      <LanguagePicker />
    </div>
  </div>
</nav>

<style>
  .main-nav {
    padding: 1.25rem 0;
    border-bottom: 5px solid #3d0066;
    box-shadow: 0 5px 0 #3d0066;
    background-color: #3d0066;
    color: #eec7fc;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
    padding: 0 5vw;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: #ffe047;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    border: 4px solid #ffe047;
    padding: 0.25rem 0.75rem;
    box-shadow: 4px 4px 0 #ffe047;
    transition: none;
  }

  .logo:hover {
    background: #ffe047;
    color: #3d0066;
    box-shadow: none;
    transform: translate(4px, 4px);
  }

  .nav-links {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .nav-link {
    text-decoration: none;
    color: #eec7fc;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    padding: 0.5rem 1.25rem;
    border-right: 2px solid rgba(238, 199, 252, 0.2);
    transition: none;
  }

  .nav-link:first-child {
    border-left: 2px solid rgba(238, 199, 252, 0.2);
  }

  .nav-link:hover {
    background: #ffe047;
    color: #3d0066;
    border-color: #ffe047;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .nav-container {
      flex-wrap: wrap;
      justify-content: space-between;
      padding: 0 1.5rem;
    }

    .nav-links {
      order: 3;
      width: 100%;
      justify-content: center;
      gap: 0;
    }
  }
</style>
