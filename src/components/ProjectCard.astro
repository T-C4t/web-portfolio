---
import type { Project, ProjectCategory } from '../data/projects';

interface Props {
  project: Project;
  lang: 'en' | 'cs';
}

const { project, lang } = Astro.props;

// Softer pastel-tinted header colors per category
const colorMap: Record<string, string> = {
  'web': '#ffe566',
  'app': '#dbb5ff',
  'design': '#ffd580',
  'other': '#d4b8f0',
};
const headerBg = colorMap[project.category] ?? '#ffe566';
---

<article class="project-card" data-category={project.category}>
  <div class="project-image" style={`background: ${headerBg};`}>
    <span class="project-category">{project.category}</span>
  </div>
  
  <div class="project-content">
    <h3 class="project-title">{project.title[lang]}</h3>
    <p class="project-description">{project.description[lang]}</p>
    
    <div class="project-tags">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    
    <div class="project-links">
      {project.liveUrl && (
        <a href={project.liveUrl} class="project-link" target="_blank" rel="noopener noreferrer">
          {lang === 'en' ? 'View' : 'Zobrazit'} →
        </a>
      )}
      {project.repoUrl && (
        <a href={project.repoUrl} class="project-link" target="_blank" rel="noopener noreferrer">
          {lang === 'en' ? 'Code' : 'Kód'} →
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: #ede0f8;
    box-shadow: 4px 4px 0 #3d0066;
    border: 3px solid #3d0066;
    border-radius: 0;
    overflow: hidden;
    transition: none;
  }

  .project-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #3d0066;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0.75rem 1rem;
    border-bottom: 3px solid #3d0066;
  }

  .project-category {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #3d0066;
    background: rgba(255,255,255,0.5);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-mono);
  }

  .project-content {
    padding: 1.25rem;
  }

  .project-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 0.5rem 0;
    color: #3d0066;
    line-height: 1.3;
  }

  .project-description {
    font-size: 0.8125rem;
    color: #3d0066;
    opacity: 0.8;
    margin: 0 0 1rem 0;
    line-height: 1.6;
    font-family: var(--font-mono);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.6rem;
    padding: 0.2rem 0.5rem;
    background: #4a0080;
    color: #ffe566;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-link {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: #3d0066;
    text-decoration: none;
    border-bottom: 2px solid #3d0066;
    padding-bottom: 0.125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-link:hover {
    color: #6b00b3;
    border-bottom-color: #6b00b3;
  }
</style>
