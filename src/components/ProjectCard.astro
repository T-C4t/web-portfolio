---
import type { Project, ProjectCategory } from '../data/projects';

interface Props {
  project: Project;
  lang: 'en' | 'cs';
}

const { project, lang } = Astro.props;

// Cycle accent colors per category for visual variety
const colorMap: Record<string, string> = {
  'web': '#ffe047',
  'app': '#c670ff',
  'design': '#ffce1f',
  'other': '#eec7fc',
};
const headerBg = colorMap[project.category] ?? '#ffe047';
---

<article class="project-card" data-category={project.category}>
  <div class="project-image" style={`background: ${headerBg};`}>
    <span class="project-category">{project.category}</span>
  </div>
  
  <div class="project-content">
    <h3 class="project-title">{project.title[lang]}</h3>
    <p class="project-description">{project.description[lang]}</p>
    
    <div class="project-tags">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    
    <div class="project-links">
      {project.liveUrl && (
        <a href={project.liveUrl} class="project-link" target="_blank" rel="noopener noreferrer">
          {lang === 'en' ? 'View' : 'Zobrazit'} →
        </a>
      )}
      {project.repoUrl && (
        <a href={project.repoUrl} class="project-link" target="_blank" rel="noopener noreferrer">
          {lang === 'en' ? 'Code' : 'Kód'} →
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: #eec7fc;
    box-shadow: 6px 6px 0 #3d0066;
    border: 4px solid #3d0066;
    border-radius: 0;
    overflow: hidden;
    transition: none;
  }

  .project-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 #3d0066;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0.75rem 1rem;
    border-bottom: 4px solid #3d0066;
  }

  .project-category {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #3d0066;
    background: rgba(255,255,255,0.6);
    padding: 0.125rem 0.5rem;
    font-family: var(--font-mono);
  }

  .project-content {
    padding: 1.5rem;
  }

  .project-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.125rem;
    margin: 0 0 0.625rem 0;
    color: #3d0066;
    line-height: 1.3;
  }

  .project-description {
    font-size: 0.875rem;
    color: #3d0066;
    opacity: 0.75;
    margin: 0 0 1rem 0;
    line-height: 1.6;
    font-family: var(--font-mono);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.625rem;
    padding: 0.25rem 0.625rem;
    background: #3d0066;
    color: #ffe047;
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-link {
    font-size: 0.8125rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: #3d0066;
    text-decoration: none;
    border-bottom: 3px solid #3d0066;
    padding-bottom: 0.125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-link:hover {
    color: #c670ff;
    border-bottom-color: #c670ff;
  }
</style>
